```python
import subprocess
import json
import sys
import os

# First, let's check what skills are actually installed
print("=== Checking Installed Skills ===\n")

# Check if opsdroid is available and list skills
try:
    result = subprocess.run(['opsdroid', '--version'], capture_output=True, text=True)
    print(f"Opsdroid version: {result.stdout.strip() if result.returncode == 0 else 'Not available'}")
except FileNotFoundError:
    print("Opsdroid not found in PATH")

# Let's check the skills directory structure
print("\n=== Checking Skills Directory Structure ===\n")

# Common opsdroid skill locations
possible_locations = [
    '/skills',
    '/etc/opsdroid/skills',
    os.path.expanduser('~/.opsdroid/skills'),
    './skills'
]

for location in possible_locations:
    if os.path.exists(location):
        print(f"Found skills directory: {location}")
        try:
            skills = os.listdir(location)
            print(f"Skills found: {skills}")
        except:
            pass

# Now let's check each specific skill mentioned
skills_to_check = ['github', 'hardware', 'skill-creator', 'summarize', 'tmux', 'weather']

print("\n=== Checking Individual Skills ===\n")

for skill_name in skills_to_check:
    print(f"\n--- Checking skill: {skill_name} ---")
    
    # Check if skill directory exists
    skill_found = False
    for location in possible_locations:
        skill_path = os.path.join(location, skill_name)
        if os.path.exists(skill_path):
            print(f"✓ Found at: {skill_path}")
            skill_found = True
            
            # Check for __init__.py or config files
            init_file = os.path.join(skill_path, '__init__.py')
            if os.path.exists(init_file):
                print(f"  ✓ Has __init__.py file")
            
            # Check for requirements.txt or setup.py
            req_file = os.path.join(skill_path, 'requirements.txt')
            if os.path.exists(req_file):
                print(f"  ✓ Has requirements.txt")
                with open(req_file, 'r') as f:
                    deps = f.read().strip().split('\n')
                    print(f"  Dependencies: {deps}")
            
            # Check for config.yaml or similar
            config_files = [f for f in os.listdir(skill_path) if 'config' in f.lower() or '.yaml' in f or '.yml' in f]
            if config_files:
                print(f"  Config files: {config_files}")
            
            break
    
    if not skill_found:
        print(f"✗ Skill directory not found in common locations")

# Let's also check Python imports for these skills
print("\n=== Checking Python Imports ===\n")

skill_modules = {
    'github': ['github', 'requests'],
    'hardware': ['psutil', 'gpiozero', 'RPi.GPIO'],
    'skill-creator': ['opsdroid'],
    'summarize': ['nltk', 'sumy', 'transformers'],
    'tmux': ['libtmux', 'subprocess'],
    'weather': ['requests', 'pyowm', 'weather-api']
}

for skill, modules in skill_modules.items():
    print(f"\n{skill}:")
    for module in modules:
        try:
            __import__(module)
            print(f"  ✓ {module}")
        except ImportError:
            print(f"  ✗ {module} (missing)")
        except Exception as e:
            print(f"  ? {module} (error: {str(e)[:50]}...)")

# Check system dependencies
print("\n=== Checking System Dependencies ===\n")

system_commands = {
    'tmux': ['tmux', '-V'],
    'git': ['git', '--version'],
    'curl': ['curl', '--version'],
    'python': ['python3', '--version']
}

for cmd, test_cmd in system_commands.items():
    try:
        result = subprocess.run(test_cmd, capture_output=True, text=True)
        if result.returncode == 0:
            print(f"✓ {cmd}: {result.stdout.split()[0] if result.stdout else 'Available'}")
        else:
            print(f"✗ {cmd}: Not available")
    except FileNotFoundError:
        print(f"✗ {cmd}: Not installed")

# Test basic functionality if possible
print("\n=== Testing Basic Skill Functionality ===\n")

# Test weather skill with a simple API check
try:
    import requests
    # Test if we can make a basic request
    test_response = requests.get('https://httpbin.org/get', timeout=5)
    if test_response.status_code == 200:
        print("✓ Network connectivity: OK")
    else:
        print("✗ Network connectivity: Issues")
except Exception as e:
    print(f"✗ Network test failed: {str(e)[:50]}")

# Test hardware monitoring if psutil is available
try:
    import psutil
    cpu_percent = psutil.cpu_percent(interval=0.1)
    memory = psutil.virtual_memory()
    print(f"✓ Hardware monitoring: CPU={cpu_percent}%, Memory={memory.percent}%")
except ImportError:
    print("✗ Hardware monitoring: psutil not available")
except Exception as e:
    print(f"✗ Hardware monitoring error: {str(e)[:50]}")

print("\n=== Summary ===\n")
print("Skill verification completed. Check above for individual skill status.")
print("\nRecommendations:")
print("1. Install missing Python packages using: pip install <package-name>")
print("2. Install missing system dependencies using your package manager")
print("3. Ensure skills are in the correct opsdroid skills directory")
print("4. Check opsdroid configuration for skill loading")
```

